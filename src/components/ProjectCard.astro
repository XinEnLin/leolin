---
const { title, description, tags = [], icon, colorClass = 'default' } = Astro.props as {
  title: string;
  description: string;
  tags?: string[];
  icon: string;
  colorClass?: string;
};

const colorMap: Record<string, { bg: string; well: string }> = {
  blue:    { bg: 'linear-gradient(135deg, #eef1ff, #e3e9fb)', well: 'rgba(108, 140, 255, 0.16)' },
  red:     { bg: 'linear-gradient(135deg, #fdeeee, #fbe3e3)', well: 'rgba(255, 107, 107, 0.16)' },
  green:   { bg: 'linear-gradient(135deg, #eafaf0, #e0f5e9)', well: 'rgba(77, 200, 130, 0.18)' },
  orange:  { bg: 'linear-gradient(135deg, #fdf3e6, #faecd8)', well: 'rgba(220, 150, 40, 0.16)' },
  purple:  { bg: 'linear-gradient(135deg, #f6eefd, #efe3fb)', well: 'rgba(200, 130, 255, 0.16)' },
  default: { bg: 'linear-gradient(135deg, #f0f4e3, #e8f1cf)', well: 'rgba(163, 204, 46, 0.20)' },
};

const colors = colorMap[colorClass] || colorMap.default;
---

<div class="project-card">
  <div class="project-visual" style={`background: ${colors.bg}`}>
    <div class="icon-wrap" style={`background: ${colors.well}`}>{icon}</div>
  </div>
  <div class="project-arrow">↗</div>
  <div class="project-info">
    <div class="project-tags">
      {tags.map((tag: string) => <span class="project-tag">{tag}</span>)}
    </div>
    <div class="project-name">{title}</div>
    <div class="project-desc">{description}</div>
  </div>
</div>

<style>
  .project-card {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: all var(--dur-med) ease;
    cursor: pointer;
    position: relative;
  }

  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(var(--lift-md));
    box-shadow: var(--shadow-card-hover);
  }

  .project-visual {
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .icon-wrap {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    transition: transform var(--dur-med) ease;
  }

  .project-card:hover .icon-wrap { transform: scale(1.1); }

  .project-arrow {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    transition: all var(--dur-fast);
  }

  .project-card:hover .project-arrow {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-wash);
  }

  .project-info { padding: 1.8rem; }

  .project-tags {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .project-tag {
    font-size: var(--text-3xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-wash);
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-pill);
  }

  .project-name {
    font-family: var(--font-display);
    font-size: var(--text-title);
    margin-bottom: var(--space-2);
    letter-spacing: -0.01em;
  }

  .project-desc {
    font-size: var(--text-body);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
  }
</style>